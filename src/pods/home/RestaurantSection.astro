---
import type { LanguageCode } from '@content-island/api-client';
import { getRestaurantSection } from '@layouts/api';

interface Props {
  lang?: LanguageCode;
  sectionId: string;
}

const { lang = 'en', sectionId } = Astro.props;

const restaurantSection = await getRestaurantSection(lang);

const title = restaurantSection.title;
const description = restaurantSection.description;
const images = restaurantSection.images ?? [];
---

<section class="bg-bg-white md:py-big-4 md:px-big-3 flex items-center justify-center px-4 py-12" id={sectionId}>
  <div class="gap-big-2 flex w-full max-w-[var(--container-max-width)] flex-col">
    <!-- Restaurant Header -->
    <div class="gap-md flex w-full flex-col justify-center">
      <h2 class="font-title text-text m-0 text-2xl font-bold">
        {title}
      </h2>

      <!-- Italian Accent Red -->
      <div class="gap-md flex items-center" aria-hidden="true">
        <div class="bg-primary-500 h-1 w-16 rounded-sm"></div>
      </div>

      <p class="font-body text-text-85 m-0 max-w-[662px] text-sm leading-[1.4] font-normal">
        {description}
      </p>
    </div>

    <!-- Image Grid -->
    <div class="gap-lg grid w-full grid-cols-1 md:grid-cols-3">
      {
        images.map(image => (
          <div class="max-h-[300px] w-full overflow-hidden rounded-md object-cover lg:max-h-[372px]">
            <img
              src={image.url}
              alt={image.alt}
              class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
