---
import type { LanguageCode } from '@content-island/api-client';
import { getRestaurantSection } from '@layouts/api';

interface Props {
  lang?: LanguageCode;
  sectionId: string;
}

const { lang = 'en', sectionId } = Astro.props;

const restaurantSection = await getRestaurantSection(lang);

const title = restaurantSection.title;
const description = restaurantSection.description;
const images = restaurantSection.images ?? [];
---

<section class="flex items-center justify-center bg-bg-white py-12 md:py-big-4 px-4 md:px-big-3" id={sectionId}>
  <div class="flex flex-col gap-big-2 w-full max-w-[var(--container-max-width)]">
    <!-- Restaurant Header -->
    <div class="flex flex-col justify-center gap-md w-full">
      <h2 class="font-title text-2xl font-bold text-text m-0">
        {title}
      </h2>
      
      <!-- Italian Accent Red -->
      <div class="flex items-center gap-md" aria-hidden="true">
        <div class="w-16 h-1 bg-primary-500 rounded-sm"></div>
      </div>
      
      <p class="font-body text-sm font-normal text-text-85 leading-[1.4] max-w-[662px] m-0">
        {description}
      </p>
    </div>
    
    <!-- Image Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-lg w-full">
      {images.map((image) => (
        <div class="overflow-hidden rounded-md max-h-[300px] lg:max-h-[372px] w-full object-cover">
          <img 
            src={image.url} 
            alt={image.alt}
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            loading="lazy"
            decoding="async"
          />
        </div>
      ))}
    </div>
  </div>
</section>
