---
import type { LanguageCode } from '@content-island/api-client';
import { getMenuSection } from '@layouts/api';

interface Props {
  lang?: LanguageCode;
  sectionId: string;
}

const { lang = 'en', sectionId } = Astro.props;

const menuSection = await getMenuSection(lang);

const title = menuSection.title;
const description = menuSection.description;
const buttonText = menuSection.buttonText;
const menuFileUrl = menuSection.menuFile?.url;
---

<section
  class="bg-bg md:py-big-4 md:px-big-3 md:gap-big-2 flex items-center justify-center gap-8 px-4 py-12"
  id={sectionId}
>
  <div class="gap-lg flex w-full flex-col items-center">
    <!-- Menu Header -->
    <div class="gap-md flex flex-col items-center">
      <h2 class="font-title text-text m-0 text-center text-2xl font-bold">
        {title}
      </h2>

      <!-- Italian Accent Green -->
      <div class="gap-md flex items-center justify-center" aria-hidden="true">
        <div class="bg-secondary-500 h-1 w-16 rounded-sm"></div>
      </div>

      <p class="font-body text-text-85 m-0 max-w-[736px] text-center text-sm leading-[1.4] font-normal">
        {description}
      </p>
    </div>

    <!-- Menu CTA -->
    <a
      href={menuFileUrl}
      class="gap-sm py-sm-md px-md border-primary-500 text-primary-500 font-body rounded-default hover:bg-primary-600 hover:text-text-contrast inline-flex items-center border bg-transparent text-xs font-semibold no-underline transition-colors"
      download
      target="_blank"
      rel="noopener noreferrer"
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      {buttonText}
    </a>
  </div>
</section>
