---
import type { LanguageCode } from '@content-island/api-client';
import { getHero } from '@layouts/api';

interface Props {
  lang?: LanguageCode;
  contactSectionId: string;
}

const { lang = 'en', contactSectionId } = Astro.props;

const hero = await getHero(lang);

const title = hero.title;
const subtitle = hero.subtitle;
const ctaText = hero.cta;
const backgroundImage = hero.backgroundImage;
const ctaHref = `#${contactSectionId}`;
---

<section
  class="md:py-big-4 md:px-big-3 relative flex min-h-[668px] items-center justify-center overflow-hidden px-4 py-12"
  id="hero"
>
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    {
      backgroundImage.url && (
        <img
          src={backgroundImage.url}
          alt={backgroundImage.alt ?? title}
          class="h-full w-full object-cover"
          loading="eager"
        />
      )
    }
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/50 to-black/70"></div>
  </div>

  <!-- Content -->
  <div class="gap-xl relative z-10 flex max-w-[800px] flex-col items-center text-center">
    <div class="gap-lg flex flex-col items-center">
      <div class="gap-sm flex flex-col items-center">
        <h1 class="font-title text-text-contrast m-0 text-3xl font-bold drop-shadow-md">
          {title}
        </h1>
        <!-- Italian Accent (Red line) -->
        <div class="gap-sm flex items-center justify-center" aria-hidden="true">
          <div class="bg-primary-500 h-1 w-16 rounded-sm"></div>
        </div>
      </div>
    </div>

    <p class="font-title m-0 text-xl font-normal text-white drop-shadow-sm">
      {subtitle}
    </p>

    <a
      href={ctaHref}
      class="gap-sm py-md px-lg bg-primary-500 text-text-contrast font-body text-md hover:bg-primary-600 inline-flex items-center rounded-full font-bold no-underline transition-colors"
    >
      {ctaText}
    </a>
  </div>
</section>
