---
import type { LanguageCode } from '@content-island/api-client';
import { getReservationsSection } from '@layouts/api';

interface Props {
  lang?: LanguageCode;
  sectionId: string;
}

const { lang = 'en', sectionId } = Astro.props;

const reservationsSection = await getReservationsSection(lang);

const title = reservationsSection.title;
const description = reservationsSection.description;
const phone = reservationsSection.phone;
const emailLabel = reservationsSection.email ?? 'Send message';
// El email real está hardcodeado porque Content Island devuelve el label del botón, no el email
const emailAddress = 'info@ladolcetavola.com';
const additionalText = reservationsSection.additionalText;
---

<section
  class="bg-bg-white md:py-big-4 md:px-big-3 md:gap-big-2 flex items-center justify-center gap-8 px-4 py-12"
  id={sectionId}
>
  <div class="gap-big-2 flex w-full flex-col items-center">
    <!-- Contact Header -->
    <div class="gap-md flex w-full flex-col items-center">
      <h2 class="font-title text-text m-0 text-center text-2xl font-bold">
        {title}
      </h2>

      <!-- Italian Accent Red -->
      <div class="gap-md flex items-center justify-center" aria-hidden="true">
        <div class="bg-primary-500 h-1 w-16 rounded-sm"></div>
      </div>

      <p class="font-body text-text-85 m-0 max-w-[515px] text-center text-sm leading-[1.4] font-normal">
        {description}
      </p>
    </div>

    <!-- Contact Buttons -->
    <div class="gap-xl flex flex-col items-center md:flex-row">
      <a
        href={`tel:${phone.replace(/\s/g, '')}`}
        class="gap-sm py-sm-md px-lg bg-primary-500 text-text-contrast font-body hover:bg-primary-600 inline-flex items-center rounded-md text-sm font-bold no-underline transition-colors"
      >
        <svg
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
          ></path>
        </svg>
        {phone}
      </a>

      <a
        href={`mailto:${emailAddress}`}
        class="gap-sm py-sm-md px-lg bg-primary-500 text-text-contrast font-body hover:bg-primary-600 inline-flex items-center rounded-md text-sm font-bold no-underline transition-colors"
      >
        <svg
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect width="20" height="16" x="2" y="4" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
        {emailLabel}
      </a>
    </div>

    <!-- Contact Note -->
    {additionalText && <p class="font-body text-text-85 m-0 text-center text-xs font-normal">{additionalText}</p>}
  </div>
</section>
