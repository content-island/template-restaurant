---
import type { LanguageCode } from '@content-island/api-client';
import { getLocationSection } from '@layouts/api';

interface Props {
  lang?: LanguageCode;
  sectionId: string;
}

const { lang = 'en', sectionId } = Astro.props;

const locationSection = await getLocationSection(lang);

const title = locationSection.title;
const description = locationSection.description;
const addressTitle = locationSection.addressTitle;
const address = locationSection.address;
const timeTablesTitle = locationSection.timeTablesTitle;
const timeTables = locationSection.timeTables;
const mapEmbedUrl = locationSection.map_url;
---

<section
  class="bg-bg md:py-big-4 md:px-big-3 md:gap-big-2 flex items-center justify-center gap-8 px-4 py-12"
  id={sectionId}
>
  <div class="gap-xl md:gap-2xl flex w-full max-w-[var(--container-max-width)] flex-col md:flex-row-reverse">
    <!-- Location Info -->
    <div class="gap-xl py-md flex flex-1 flex-col">
      <!-- Location Header -->
      <div class="gap-md flex w-full flex-col">
        <h2 class="font-title text-text m-0 text-2xl font-bold">
          {title}
        </h2>

        <!-- Italian Accent Green -->
        <div class="gap-md flex items-center" aria-hidden="true">
          <div class="bg-secondary-500 h-1 w-16 rounded-sm"></div>
        </div>

        <p class="font-body text-text-85 m-0 w-full text-sm leading-[1.4] font-normal">
          {description}
        </p>
      </div>

      <!-- Location Details -->
      <div class="gap-lg flex w-full flex-col">
        <!-- Address -->
        <div class="gap-sm flex w-full flex-col">
          <h4 class="font-body text-md text-text-85 m-0 font-semibold">
            {addressTitle}
          </h4>
          <p class="font-body text-text-85 m-0 text-sm leading-normal font-normal">
            {address}
          </p>
        </div>

        <!-- Hours -->
        <div class="gap-sm flex w-full flex-col">
          <h4 class="font-body text-md text-text-85 m-0 font-semibold">
            {timeTablesTitle}
          </h4>
          {
            timeTables
              .split('\\n')
              .map(line => <p class="font-body text-text-85 m-0 text-sm leading-normal font-normal">{line}</p>)
          }
        </div>
      </div>
    </div>

    <!-- Map Container (visible on desktop) -->
    <div class="bg-primary-100 border-gradient flex min-h-[400px] flex-1 flex-col overflow-hidden rounded-lg">
      {
        mapEmbedUrl ? (
          <iframe
            src={mapEmbedUrl}
            class="flex-1 border-none"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Restaurant location"
          />
        ) : (
          <div class="text-text-60 gap-md flex h-full flex-col items-center justify-center">
            <svg
              width="48"
              height="48"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            <p>Map not available</p>
          </div>
        )
      }
    </div>
  </div>
</section>
