---
import { LANGUAGE_NAMES, LANGUAGES } from '@/core/constants';
import type { LanguageCode } from '@content-island/api-client';
import { getFooter } from '@layouts/api';

interface Props {
  lang?: LanguageCode;
  languagePaths?: Partial<Record<LanguageCode, string>>;
}

const { lang = 'en', languagePaths } = Astro.props;
const currentPath = Astro.url.pathname;
const [, , ...pathSegments] = currentPath.split('/').filter(Boolean);
const currentSlug = pathSegments.join('/');

const footer = await getFooter(lang);

const siteName = footer.restaurantName;
const tagline = footer.motto;
const contactInfo = footer.contactInfo;
const addressLine = footer.addressLine;
const socialMediaTitle = footer.socialMediaTitle;
const socialMediaCollection = footer.socialMediaCollection ?? [];
const copyright = footer.copyRight;
const cookiesLink = footer.cookies;
const privacyLink = footer.privacyPolicy;
---

<footer class="bg-secondary-900 md:p-xl p-4">
  <div class="gap-lg pb-md mx-auto flex w-full max-w-[var(--container-max-width)] flex-col">
    <div class="gap-xl flex w-full flex-col md:flex-row md:items-start md:justify-between">
      <!-- Left Column: Brand + Contact Info -->
      <div class="gap-xl flex flex-col">
        <!-- Brand Section -->
        <div class="gap-sm flex flex-col">
          <a
            href="/"
            class="font-title text-md text-primary-500 hover:text-primary-500-400 leading-[1.15] font-bold no-underline transition-colors"
          >
            {siteName}
          </a>
          <p class="font-body text-secondary-300 m-0 text-base">
            {tagline}
          </p>
        </div>

        <!-- Contact Info -->
        <div class="gap-sm flex flex-col">
          <p class="font-body text-secondary-50 m-0 text-base">{contactInfo}</p>
          <p class="font-body text-secondary-50 m-0 text-base">{addressLine}</p>
        </div>
      </div>

      <!-- Right Column: Social Links + Language Selector -->
      {
        socialMediaCollection.length > 0 && (
          <div class="gap-xl flex flex-col">
            <!-- Social Links -->
            <div class="gap-md flex flex-col">
              <p class="font-body text-secondary-50 m-0 text-xs font-medium">{socialMediaTitle}</p>
              <div class="gap-md flex">
                {socialMediaCollection.map(social => (
                  <a
                    href={social.url}
                    class="flex items-center justify-center transition-opacity hover:opacity-80"
                    aria-label={social.title}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {social.image?.url ? (
                      <img src={social.image.url} alt={social.title} width="24" height="24" />
                    ) : (
                      <span class="text-sm text-white">{social.title}</span>
                    )}
                  </a>
                ))}
              </div>
            </div>

            <!-- Language Selector -->
            {LANGUAGES.length > 1 && (
              <select
                id="language-select"
                aria-label="Select language"
                class="bg-primary-950 dark:bg-primary-900 text-primary-50 border-primary-50 focus-visible:outline-primary-400 w-full cursor-pointer appearance-none border bg-[url('/ArrowDown.svg')] bg-size-[28px] bg-position-[calc(100%-6px)_50%] bg-no-repeat px-(--spacing-sm) py-[6.4px] pr-[38px] text-[14px] focus-visible:border-transparent focus-visible:outline-[1.5px]"
              >
                {LANGUAGES.map(language => {
                  const slugPart = currentSlug ? `/${currentSlug}` : '/';
                  const optionValue = languagePaths?.[language] ?? `/${language}${slugPart}`;
                  return (
                    <option value={optionValue} selected={lang === language}>
                      {LANGUAGE_NAMES[language]}
                    </option>
                  );
                })}
              </select>
            )}
          </div>
        )
      }
    </div>
  </div>

  <!-- Bottom Section -->
  <div
    class="gap-sm pt-lg border-secondary-700 mx-auto flex w-full max-w-[var(--container-max-width)] flex-col items-start border-t pb-0 md:flex-row md:items-center md:justify-between"
  >
    <p class="font-body text-2xs text-secondary-200 m-0">{copyright}</p>
    <div class="gap-md flex">
      <a
        href={cookiesLink.url}
        class="font-body text-2xs text-secondary-200 hover:text-secondary-50 no-underline transition-colors"
      >
        {cookiesLink.label}
      </a>
      <a
        href={privacyLink.url}
        class="font-body text-2xs text-secondary-200 hover:text-secondary-50 no-underline transition-colors"
      >
        {privacyLink.label}
      </a>
    </div>
  </div>
</footer>

<script>
  const languageSelect = document.getElementById('language-select') as HTMLSelectElement;
  if (languageSelect) {
    languageSelect.addEventListener('change', event => {
      const target = event.target as HTMLSelectElement;
      window.location.href = target.value;
    });
  }
</script>
