---
import type { LanguageCode } from '@content-island/api-client';
import { getFooter } from '@layouts/api';

interface Props {
  lang?: LanguageCode;
}

const { lang = 'en' } = Astro.props;

const footer = await getFooter(lang);

const siteName = footer.restaurantName;
const tagline = footer.motto;
const contactInfo = footer.contactInfo;
const addressLine = footer.addressLine;
const socialMediaTitle = footer.socialMediaTitle;
const socialMediaCollection = footer.socialMediaCollection ?? [];
const copyright = footer.copyRight;
const cookiesLink = footer.cookies;
const privacyLink = footer.privacyPolicy;
---

<footer class="bg-secondary-900 p-4 md:p-xl">
  <div class="flex flex-col gap-lg w-full max-w-[var(--container-max-width)] mx-auto pb-md">
    <!-- Top Section: Brand + Social + Contact (gap-xl between them) -->
    <div class="flex flex-col gap-xl">
      <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-xl w-full">
      <!-- Brand Section -->
      <div class="flex flex-col gap-sm">
        <a href="/" class="font-title text-md font-bold text-primary-500 no-underline hover:text-primary-500-400 transition-colors leading-[1.15]">
          {siteName}
        </a>
        <p class="font-body text-base text-secondary-300 m-0">
          {tagline}
        </p>
      </div>
      
      <!-- Social Links -->
      {socialMediaCollection.length > 0 && (
        <div class="flex flex-col gap-md">
          <p class="font-body text-xs font-medium text-secondary-50 m-0">
            {socialMediaTitle}
          </p>
          <div class="flex gap-md">
            {socialMediaCollection.map((social) => (
              <a 
                href={social.url} 
                class="flex items-center justify-center hover:opacity-80 transition-opacity" 
                aria-label={social.title} 
                target="_blank" 
                rel="noopener noreferrer"
              >
                {social.image?.url ? (
                  <img 
                    src={social.image.url} 
                    alt={social.title} 
                    width="24" 
                    height="24"
                  />
                ) : (
                  <span class="text-sm text-white">{social.title}</span>
                )}
              </a>
            ))}
          </div>
        </div>
      )}
      </div>
      
      <!-- Contact Info -->
      <div class="flex flex-col gap-sm">
        <p class="font-body text-base text-secondary-50 m-0">{contactInfo}</p>
        <p class="font-body text-base text-secondary-50 m-0">{addressLine}</p>
      </div>
    </div>
  </div>
  
  <!-- Bottom Section -->
  <div class="flex flex-col md:flex-row md:justify-between items-start md:items-center gap-sm pt-lg pb-0 border-t border-secondary-700 w-full max-w-[var(--container-max-width)] mx-auto">
    <p class="font-body text-2xs text-secondary-200 m-0">{copyright}</p>
    <div class="flex gap-md">
      <a href={cookiesLink.url} class="font-body text-2xs text-secondary-200 no-underline hover:text-secondary-50 transition-colors">
        {cookiesLink.label}
      </a>
      <a href={privacyLink.url} class="font-body text-2xs text-secondary-200 no-underline hover:text-secondary-50 transition-colors">
        {privacyLink.label}
      </a>
    </div>
  </div>
</footer>
