---
import type { LanguageCode } from '@content-island/api-client';
import { getHeader } from '@layouts/api';

interface Props {
  lang?: LanguageCode;
}

const { lang = 'en' } = Astro.props;

const header = await getHeader(lang);

// Helper to convert URL to anchor link (e.g., "/menu" -> "#menu", "/#services" -> "#services")
const toAnchor = (url: string): string => {
  const cleaned = url.replace(/^\/?#?/, '');
  return `#${cleaned}`;
};

const siteName = header.restaurantName.label;
const homeUrl = header.restaurantName.url;

const navLinks = [
  { label: header.Menu.label, href: toAnchor(header.Menu.url) },
  { label: header.Restaurant.label, href: toAnchor(header.Restaurant.url) },
  { label: header.Location.label, href: toAnchor(header.Location.url) },
];
const ctaText = header.Contact.label;
const ctaHref = toAnchor(header.Contact.url);
---

<!-- Desktop Header -->
<header
  class="py-lg md:px-big-3 bg-bg-white border-border sticky top-0 z-[100] hidden items-center justify-between border-b px-4 md:flex"
>
  <a
    href={homeUrl}
    class="font-title text-primary-500 hover:text-primary-500-700 text-lg font-normal no-underline transition-colors"
  >
    {siteName}
  </a>

  <nav class="gap-xl flex items-center">
    <ul class="gap-xl m-0 flex list-none items-center p-0">
      {
        navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class="font-body text-text hover:text-primary-500 text-sm font-medium no-underline transition-colors"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      href={ctaHref}
      class="gap-xs py-sm px-lg bg-primary-500 text-text-contrast font-body hover:bg-primary-600 flex items-center rounded-full text-xs font-semibold no-underline transition-colors"
    >
      {ctaText}
    </a>
  </nav>
</header>

<!-- Mobile Header -->
<header class="py-sm px-sm-md bg-bg-white sticky top-0 z-[100] flex items-center justify-between md:hidden">
  <a href={homeUrl} class="font-title text-md text-primary-500 font-bold no-underline">
    {siteName}
  </a>

  <button
    class="hamburger flex h-10 w-10 cursor-pointer flex-col justify-center gap-1.5 border-none bg-transparent p-2"
    aria-label="Abrir menú"
    aria-expanded="false"
    data-menu-toggle
  >
    <span class="hamburger-line bg-text block h-0.5 w-6 rounded-sm"></span>
    <span class="hamburger-line bg-text block h-0.5 w-6 rounded-sm"></span>
    <span class="hamburger-line bg-text block h-0.5 w-6 rounded-sm"></span>
  </button>
</header>

<!-- Mobile Menu Overlay -->
<div class="mobile-menu bg-bg-white p-xl fixed inset-0 top-12 z-[99] flex flex-col md:hidden" data-mobile-menu>
  <nav class="gap-xl flex h-full flex-col justify-between">
    <ul class="gap-lg m-0 flex list-none flex-col p-0">
      {
        navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class="font-body text-text hover:text-primary-500 text-lg font-medium no-underline"
              data-menu-close
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      href={ctaHref}
      class="gap-sm py-md px-lg bg-primary-500 text-text-contrast font-body text-md inline-flex items-center justify-center rounded-full font-bold no-underline"
      data-menu-close
    >
      {ctaText}
    </a>
  </nav>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const menuToggle = document.querySelector('[data-menu-toggle]');
    const mobileMenu = document.querySelector('[data-mobile-menu]');
    const menuCloseLinks = document.querySelectorAll('[data-menu-close]');

    // Mobile menu toggle
    if (menuToggle && mobileMenu) {
      menuToggle.addEventListener('click', () => {
        const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
        menuToggle.setAttribute('aria-expanded', String(!isExpanded));
        menuToggle.classList.toggle('active');
        mobileMenu.classList.toggle('active');
        document.body.classList.toggle('menu-open');
      });

      menuCloseLinks.forEach(link => {
        link.addEventListener('click', () => {
          menuToggle.setAttribute('aria-expanded', 'false');
          menuToggle.classList.remove('active');
          mobileMenu.classList.remove('active');
          document.body.classList.remove('menu-open');
        });
      });
    }

    // Smooth scroll with header offset
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', e => {
        const href = anchor.getAttribute('href');
        if (!href || href === '#') return;

        const target = document.querySelector(href);
        if (!target) return;

        e.preventDefault();

        // Get header height for offset
        const header = document.querySelector('header');
        const headerHeight = header?.offsetHeight ?? 0;

        const targetPosition = target.getBoundingClientRect().top + window.scrollY - headerHeight;

        window.scrollTo({
          top: targetPosition,
          behavior: 'smooth',
        });

        // Update URL without jumping
        history.pushState(null, '', href);
      });
    });
  });
</script>
