{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/common/components/*"],
      "@models/*": ["src/common/models/*"],
      "@layouts/*": ["src/layouts/*"],
      "@pods/*": ["src/pods/*"],
      "@lib/*": ["src/lib/*"]
    }
  }
}
